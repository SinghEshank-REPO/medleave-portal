# ==========================================
# MedLeave Portal Environment Configurations
# ==========================================

# --- BACKEND SETTINGS ---
PORT=5000
NODE_ENV=development

# Database Connection (Docker PostgreSQL default)
DATABASE_URL="postgresql://postgres:postgrespassword@localhost:5432/medleave_db?schema=public"

# SQLite Alternative (Uncomment this and modify schema.prisma provider to "sqlite" if docker is not running)
# DATABASE_URL="file:./dev.db"

# JWT Authentication
JWT_SECRET="super-secret-key-change-in-production-12345"
JWT_EXPIRES_IN="7d"

# Cloudinary Storage Configuration
# Set to 'mock' to save files to backend/uploads directory instead of Cloudinary
CLOUDINARY_CLOUD_NAME="mock"
CLOUDINARY_API_KEY="mock"
CLOUDINARY_API_SECRET="mock"

# OpenAI API Configuration
# Set to 'mock' to run heuristic rule-based OCR parsing and diagnosis extraction
OPENAI_API_KEY="mock"

# --- FRONTEND SETTINGS ---
# API URL of the Express backend
NEXT_PUBLIC_API_URL="http://localhost:5000/api"
